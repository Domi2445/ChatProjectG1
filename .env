# Database configuration for external Oracle/FreeSQL setup
# Fill in your real values before running against external DB.
DB_URL=jdbc:oracle:thin:@//HOST:1521/SERVICE_NAME
DB_USER=YOUR_USERNAME
DB_PASSWORD=YOUR_PASSWORD

# Development default: let Hibernate update/create schema as needed
DB_DDL=update

# Optional SQL debug output
# DB_SHOW_SQL=true
# DB_FORMAT_SQL=true

