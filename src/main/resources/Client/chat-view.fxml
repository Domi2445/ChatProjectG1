<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="Client.Controller"
            style="-fx-background-color: #1e1e2e;">
	<top>
		<HBox alignment="CENTER_LEFT" spacing="10"
		      style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 0 0 1 0;"
		      BorderPane.alignment="CENTER">
			<padding>
				<Insets top="10" right="14" bottom="10" left="14"/>
			</padding>
			<Label style="-fx-text-fill: #cdd6f4; -fx-font-size: 18;" text="Socket Chat"/>
			<Region HBox.hgrow="ALWAYS"/>
			<Button fx:id="videoCallButton" mnemonicParsing="false"
			        style="-fx-background-color: #45475a; -fx-text-fill: #cdd6f4; -fx-font-size: 14; -fx-background-radius: 20; -fx-min-width: 70; -fx-min-height: 40;"
			        text="Call"/>
		</HBox>
	</top>

	<center>
		<ListView fx:id="messageListView"
		          style="-fx-background-color: #1e1e2e; -fx-control-inner-background: #1e1e2e;"/>
	</center>

	<bottom>
		<HBox alignment="CENTER" spacing="8"
		      style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 1 0 0 0;"
		      BorderPane.alignment="CENTER">
			<padding>
				<Insets top="10" right="14" bottom="10" left="14"/>
			</padding>
			<Button fx:id="uploadButton" mnemonicParsing="false"
			        style="-fx-background-color: #45475a; -fx-text-fill: #cdd6f4; -fx-font-size: 14; -fx-background-radius: 20; -fx-min-width: 70; -fx-min-height: 40;"
			        text="Upload"/>
			<TextField fx:id="messageTextField" promptText="Nachricht eingeben..."
			           style="-fx-background-color: #2a2a3d; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 14;"
			           HBox.hgrow="ALWAYS"/>
			<Button fx:id="sendButton" mnemonicParsing="false"
			        style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e; -fx-font-size: 14; -fx-background-radius: 20; -fx-min-width: 70; -fx-min-height: 40;"
			        text="Send"/>
		</HBox>
	</bottom>
</BorderPane>

